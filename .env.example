# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.
# In production, set these in the Vercel dashboard (Project Settings → Environment Variables).

# Supabase (added in Phase 3). Find these in your Supabase project:
# Project Settings → API. The anon/publishable key is safe to expose to the browser
# (it is protected by Row Level Security); the service role key must NEVER be used client-side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
