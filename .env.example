# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.
# In production, set these in the Vercel dashboard (Project Settings → Environment Variables).

# Supabase — find these in your project: Project Settings → API.
# The publishable key is safe to expose in the browser (it is protected by Row
# Level Security). Never use the service_role/secret key in client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Postgres connection string, used ONLY for running migrations
# locally (the app does not use it). Never expose it or add it to Vercel.
# Supabase → Project Settings → Database → Connection string (URL-encode the password).
SUPABASE_DB_URL=
